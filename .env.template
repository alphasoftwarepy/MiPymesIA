# MiPymesIA - Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI API Key (Required)
OPENAI_API_KEY=your_openai_api_key_here

# Google Sheets IDs (Required)
GOOGLE_SHEETS_ESTRATEGIAS_ID=your_estrategias_sheet_id_here
GOOGLE_SHEETS_NEGOCIOS_ID=your_negocios_sheet_id_here

# Optional: OpenRouter API Key (for alternative AI models)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Database path (defaults to users.db)
# DATABASE_PATH=users.db

# Optional: Application settings
# DEBUG=False
# PORT=8501
